    cxp.change_data::&db,&params,&data
    {
        new dcxp
        {
            @"f_prevpago":@@(data,"$f_prevpago")
        }
        do dbr.update(db,"dcxp",dcxp,"sys_pk=@_entity_id",params)
        
        return dcxp
    }
}
#include "dkli.dkh"
#!
module "model"
{
    @table_name = "dcxp"
    @read_query = "
    SELECT
        cxp.sys_pk,
        cxp.sys_guid,
        DATE_FORMAT(cxp.sys_dtcreated,'%Y-%m-%d %H:%i:%s') AS sys_dtcreated,
        DATE_FORMAT(cxp.sys_timestamp,'%Y-%m-%d %H:%i:%s') AS sys_timestamp,
        IFNULL(cxp.sys_recver,0) AS sys_recver,
        cxp.aplicable,
        cxp.referencia,
        cxp.documento,
        DATE_FORMAT(cxp.fecha,'%Y-%m-%d') AS emision,
        DATE_FORMAT(cxp.fultmoratorios,'%Y-%m-%d') AS fultmoratorios,
        DATE_FORMAT(cxp.aplicacion,'%Y-%m-%d') AS aplicacion,
        ROUND(IFNULL(cxp.debe,0),@decimals) AS debe,
        ROUND(IFNULL(cxp.haber,0),@decimals) AS haber,
        ROUND(IFNULL(cxp.intmoratorios,0),@decimals) AS intmoratorios,
        ROUND(IFNULL(cxp.intfinancieros,0),@decimals) AS intfinancieros,
        ROUND(IFNULL(cxp.pagos,0),@decimals) AS pagos,
        ROUND(IFNULL(cxp.bonificaciones,0),@decimals) AS bonificaciones,
        ROUND(IFNULL(cxp.haber,0) + IFNULL(cxp.intmoratorios,0) - IFNULL(cxp.pagos,0) - IFNULL(cxp.bonificaciones,0),@decimals) AS saldo,
        ROUND(cxp.tipocambio,@decimals) tipocambio,
        cxp.xaplicar,
        cxp.iproveedor,
        cxp.notas,
        pdr.codigo AS cproveedor,
        pdr.nombre AS proveedor,
        pdr.saldo AS saldoprov,
        dvs.codigo AS divisa,
        date_format(cxp.f_autorizacion,'%Y-%m-%d')f_autorizacion,
        date_format(cxp.f_autorizacion2,'%Y-%m-%d')f_autorizacion2,
        date_format(cxp.f_prevpago,'%Y-%m-%d')f_prevpago,
        cxp.u_autorizo,
        cxp.u_autorizo2,
        t1.username user_auth,        
        t2.username user_auth2,
        cxp.autorizado,
        if(NOW() > cxp.fultmoratorios,NOW(),cxp.fultmoratorios) fecha_prevpago
    FROM dcxp AS cxp
        INNER JOIN proveedor AS pdr ON pdr.sys_pk = cxp.iproveedor
        INNER JOIN divisa AS dvs ON dvs.sys_pk = pdr.idivisa
        LEFT JOIN tuser t1 on cxp.u_autorizo=t1.userid        
        LEFT JOIN tuser t2 on cxp.u_autorizo2=t2.userid
    WHERE cxp.#<@keyfield> = @_entity_id
    "

    cxp.prepareView::&db,&params,&data
    {
        if not(field.exist(params,"decimals")){ params<"decimals"> : parse.num(dbr.vars.get(db,"FXCA001")) }

        sql_get_proveedor = "
        SELECT 
            pdr.sys_pk,
            pdr.codigo,
            pdr.nombre,
            tpp.descripcion AS tipo,
            dvs.codigo AS divisa,
            dvs.tcambio
        FROM proveedor AS pdr 
            INNER JOIN tipoproveedor AS tpp ON tpp.sys_pk = pdr.tipo
            INNER JOIN divisa AS dvs ON dvs.sys_pk = pdr.idivisa
        WHERE #<condition>"

        switch @@(params,"$_view")
        {
            case ""
            {
                sql_documentos = "SELECT doc.id, doc.const FROM cdocumentos AS doc INNER JOIN cfg_cxp_docs AS cfg ON cfg.documento = doc.id WHERE IFNULL(cfg.pagable,0);"

                if @@(params,"$_entity_id") == "_new"
                {
                    if @@(data,"#form/iproveedor") > 0 {
                        condition = "pdr.sys_pk = @iproveedor;"
                        data<"info_proveedor*"> : dbr.rec(db,ftext(sql_get_proveedor),@@(data,"&form"))
                    }
                    else if @@(params,"$prov") != "" {
                        condition = "pdr.sys_pk = @prov OR pdr.codigo = @prov;"
                        data<"info_proveedor*"> : dbr.rec(db,ftext(sql_get_proveedor),params)
                    }

                    data<"documentos*"> : dbr.list(db,sql_documentos,@null)
                }
                else 
                {
                    ref info_dcxp = record.copy(data,"*")
                    do record.clear(data)

                    new p { @"iproveedor": @@(info_dcxp,"#iproveedor") }
                    condition = "pdr.sys_pk = @iproveedor"
                    ref info_prov = dbr.rec(db,ftext(sql_get_proveedor),p)
                    
                    data<"info_dcxp*"> : info_dcxp
                    data<"info_proveedor*"> : info_prov
                    data<"documentos*"> : dbr.list(db,sql_documentos,@null)
                }
                break
            }
            case "bonificacion"
            {
                ref dcxp = entity.read(db,params)
                // if not(dbr.security.isauth(db,@CXP_SEC_PRIVID_APLICAR_BONIFICACION)) { do rise_error(0,"No autorizado") }
                if @@(dcxp,"#haber") <= 0 { do rise_error(500,"No es posible bonificar el documento proporcionado") }

                sql_documentos = "SELECT doc.id, doc.const FROM cdocumentos AS doc INNER JOIN cfg_cxp_docs AS cfg ON cfg.documento = doc.id WHERE IFNULL(cfg.apl_bonific,0);"

                data<"info_dcxp*"> : dcxp
                data<"documentos*"> : dbr.list(db,sql_documentos,@null)
                break
            }
            case "pago"
            {
                ref dcxp = entity.read(db,params)
                // if not(dbr.security.isauth(db,@CXP_SEC_PRIVID_APLICAR_ABONO)) { do rise_error(0,"No autorizado") }
                if @@(dcxp,"#haber") <= 0 { do rise_error(500,"No es posible pagar el documento proporcionado") }

                sql_documentos = "SELECT doc.id, doc.const FROM cdocumentos AS doc INNER JOIN cfg_cxp_docs AS cfg ON cfg.documento = doc.id WHERE IFNULL(cfg.apl_pago,0);"
                sql_doc_retiro = "SELECT doc.id, doc.const FROM cdocumentos AS doc INNER JOIN cfg_chq_docs AS cfg ON cfg.documento = doc.id WHERE IFNULL(cfg.retiros,0);"
                sql_cuentas = "SELECT c.sys_pk, d.codigo AS divisa, d.tcambio, CONCAT(c.nombre,'(',d.codigo,')') nombre FROM chequera c INNER JOIN divisa d ON d.sys_pk = c.idivisa WHERE NOT IFNULL(c.sys_deleted,0) ORDER BY c.sys_pk;"
                sql_cat_egreso = "SELECT sys_pk,descripcion FROM categoria WHERE tipo = 2 AND NOT IFNULL(sys_deleted,0) ORDER BY sys_pk;"
                
                data<"info_dcxp*"> : dcxp
                data<"documentos*"> : dbr.list(db,sql_documentos,@null)
                data<"documentos_cuenta*"> : dbr.list(db,sql_doc_retiro,@null)
                data<"cuentas*"> : dbr.list(db,sql_cuentas,@null)
                data<"categorias*"> : dbr.list(db,sql_cat_egreso,@null)
                break
            }
            case "intmoratorios"
            {
                ref dcxp = entity.read(db,params)
                // if not(dbr.security.isauth(db,@CXP_SEC_PRIVID_CARGO_POR_MORA)) { do rise_error(0,"No autorizado") }
                if @@(dcxp,"#haber") <= 0 { do rise_error(500,"No es posible aplicar intereses moratorios al documento proporcionado") }

                sql_documentos = "SELECT doc.id, doc.const FROM cdocumentos AS doc INNER JOIN cfg_cxp_docs AS cfg ON cfg.documento = doc.id WHERE IFNULL(cfg.apl_int_mor,0);"

                data<"info_dcxp*"> : dcxp
                data<"documentos*"> : dbr.list(db,sql_documentos,@null)
                break
            }
        }

        using data
        {
            @"dvs_pred*": dbr.localize.money(db,@dbr.localize.default.money_code)
            @"decimals": @@(params,"#decimals")
        }
    }

    cxp.crearDocumentoPorPagar::&db,&params,&data
    {
        //if not(dbr.security.isauth(db,@CXP_SEC_PRIVID_AGREGAR_DCXP)) { do rise_error(0,"No autorizado") }
        @use_transaction = @false

        do dbr.apps.action.pre("GC11")
        do dbr.begin(db)

        do erp.cxp.movimientos.crearCxP(db,data)

        do dbr.apps.action.pos(@null)
        do dbr.commit(db)
        do dbr.apps.action.ext(@null)

        // @url_redir = @CXP_DOCS

        exception
        {
            do errordet(@false)
            if dbr.in_transaction(db) { do dbr.rollback(db) }

            ref formData = record.copy(data,"*")
            code = last_error_code()
            error = last_error()

            do record.clear(data)
            data<"form*"> : formData
            
            do cxp.prepareView(db,params,data)
            do dbr.apps.action.log()
            do rise_error(code,error)
        }
    }

    cxp.pagarDocumento::&db,&params,&data
    {
        //if not(dbr.security.isauth(db,@CXP_SEC_PRIVID_APLICAR_ABONO)) { do rise_error(0,"No autorizado")}
        @use_transaction = @false

        do dbr.apps.action.pre("GC13")
        do dbr.begin(db)
        
        do cxp.CheckAuth(db,params)

        if @@(data,"#pkparent")>0{params<"pkparent">:@@(data,"#pkparent")}
        do cxp.validateAplicable(db,params)

        do erp.cxp.movimientos.pagarCxP(db,data)

        do dbr.apps.action.pos(@null)
        do dbr.commit(db)
        do dbr.apps.action.ext(@null)

        // @url_redir = @CXP_DOCS

        exception
        {
            do errordet(@false)
            if dbr.in_transaction(db) { do dbr.rollback(db) }

            ref formData = record.copy(data,"*")
            code = last_error_code()
            error = last_error()

            do record.clear(data)
            data<"form*"> : formData
            
            do cxp.prepareView(db,params,data)
            do dbr.apps.action.log()
            do rise_error(code,error)
        }
    }


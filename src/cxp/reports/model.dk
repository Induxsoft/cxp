#include "dkli.dkh"
#!
module "Reportes de Cuentas por Pagar"
{
    prepareView::&db,&params,&data
    {
        if not(field.exist(params,"decimals")){ params<"decimals"> : parse.num(dbr.vars.get(db,"FXCA001")) }

        sql_tiposproveedor = "SELECT sys_pk, descripcion FROM tipoproveedor WHERE NOT IFNULL(sys_deleted,0)"

        switch @@(@http_context,"$request/get/_entity_id")
        {
            case "antiguedad-saldos"
            {
                using data
                {
                    @"list_tipos*": dbr.list(db,sql_tiposproveedor,@null)
                }
                break
            }
            case "historial-pagos-proveedor"
            {
                using data
                {
                    @"list_tipos*": dbr.list(db,sql_tiposproveedor,@null)
                    @"list_docs*": dbr.list(db,"SELECT * FROM cdocumentos WHERE id IN (5,19);",@null)
                }
                break
            }
        }

        do prepareDefaultReportData(db,data)
    }

    prepareDefaultReportData::&db,&data
    {
        using data
        {
            member @"titles"
            {
                @"title": dbr.vars.getd(db,"FXCA108","")
                @"subtitle": dbr.vars.getd(db,"FXCA109","")
                @"subtitle_2": dbr.vars.getd(db,"FXCA110","")
                @"footer": dbr.vars.getd(db,"FXCA111","")
            }
        }
    }

    antiguedadSaldos::&db,&params
    {
        do dbr.apps.action.grant("GC41")

        sql_antiguedad_saldo = "
        SELECT
            dcxp.sys_pk,
            DATE_FORMAT(dcxp.aplicacion,'%d/%m/%Y') AS aplicacion,
            DATE_FORMAT(dcxp.fecha,'%d/%m/%Y') AS fecha,
            dcxp.referencia,
            z.codigo,
            z.nombre,
            z.rfc,
            z.telefonos,
            cdocumentos.const AS documento,
            DATEDIFF(@fil_fcorte, dcxp.aplicacion) AS dias,
            (dcxp.haber + dcxp.intmoratorios - dcxp.bonificaciones - dcxp.pagos) AS saldo
        FROM
            (
                proveedor z
                INNER JOIN (
                    cdocumentos
                    INNER JOIN dcxp ON cdocumentos.id = dcxp.documento
                ) ON z.sys_pk = dcxp.iproveedor
            )
        WHERE
            dcxp.aplicable <> 0
            AND (dcxp.haber + dcxp.intmoratorios - dcxp.bonificaciones - dcxp.pagos) <> 0
            #<conditions>
        ORDER BY z.nombre;
        "

        conditions = ""
        if not(field.exist(params,"fil_fcorte")) { params<"fil_fcorte"> : hoy("yyyy-MM-dd") }
        if replace(@@(params,"$fil_tipo"),"*","") != "" { conditions = conditions + " AND z.tipo = @fil_tipo" }

        new data
        {
            @"list*": dbr.list(db,ftext(sql_antiguedad_saldo),params)
        }
        do prepareView(db,params,data)

        return data

        exception{ do catch() }
    }

    origenAplicacion::&db,&params
    {
        do dbr.apps.action.grant("GC42")

        sql = "
        select
            a.destino,
            a.sys_pk kapp,
            x.aplicacion fapl,
            x.referencia origen,
            y.fecha fdoc,
            y.aplicacion fcxp,
            y.referencia aplicacion,
            if(a.destino=3,a.importe,0) bonificaciones,
            if(a.destino=4,a.importe,0) pagos,
            p.codigo,
            p.nombre,
            y.haber importe,
            y.bonificaciones ac_bonificaciones,
            y.pagos ac_pagos,
            y.haber+y.intmoratorios - y.bonificaciones-y.pagos saldo
        from aplcxp a
            inner join dcxp x on a.fk_dcxp_aplicadoa=x.sys_pk
            inner join dcxp y on a.aplicadoa=y.sys_pk 
            inner join proveedor p on y.iproveedor=p.sys_pk
        where y.fecha between @finicio and @ffinal
        order by y.fecha, y.sys_pk, x.aplicacion
        ;"

        new data
        {
            @"data*": dbr.list(db,sql,params)
        }
        do prepareView(db,params,data)

        return data

        exception{ do catch() }
    }

    historialPagosXProveedor::&db,&params
    {
      do dbr.apps.action.grant("GC43")

        sql = "
        SELECT
            DATE_FORMAT(cxp.fecha,'%Y-%m-%d') AS fecha,
            doc.id AS idocumento,
            doc.const AS cdocumento,
            cxp.referencia,
            cxp.notas AS descripcion,
            cxp.debe AS importe,
            cxp.iproveedor,
            pdr.codigo AS cproveedor,
            pdr.nombre AS `proveedor`
        FROM proveedor AS pdr
            INNER JOIN dcxp AS cxp ON cxp.iproveedor = pdr.sys_pk
            INNER JOIN cdocumentos AS doc ON cxp.documento = doc.id
        WHERE
            cxp.debe > 0
            AND cxp.fecha BETWEEN IFNULL(@finicio,date(now())) AND IFNULL(@ffinal, date(now()))
            AND IF(CONVERT(@pktipo,DECIMAL)>0, pdr.tipo = @pktipo, TRUE)
            AND IF(CONVERT(@doctype,DECIMAL)>0, cxp.documento = @doctype, (cxp.documento=5 OR cxp.documento=19))
        ORDER BY
            cxp.iproveedor,
            cxp.fecha,
            cxp.debe;
        "

        new data
        {
            @"data*": dbr.list(db,sql,params)
        }
        do prepareView(db,params,data)
        return data

        exception{ do catch() }
    }

    NotImplemented::&db,&params { do rise_error(404,"Reporte no implementado") }

    catch::
    {
        do errordet(@false)
        code = last_error_code()
        error = last_error()

        if isset("@@_action_context"){ do dbr.apps.action.log() }
        do rise_error(code,error)
    }
}
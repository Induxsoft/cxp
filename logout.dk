#include "dkli.dkh"
#!
module "logout"
{
	#include "functions.dkh"
	#include "serialize.dkh"
	#include "dbr.dkh"
	#include "config.dk"

	ids=@@(@http_context,"request/get/ids")

	if trim(ids)==""{ids=@@(@http_context,"$session/user/ids")}
		
	url=@@(@http_context,"request/get/url")

	ref db=dbr.reconnect(@qname.crud,ids)

	do dbr.logout(db)

	@http_context<"response/headers/location">:"/login.dk"
}

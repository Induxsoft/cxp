<html>

<head>
    <title>Sipbsa dev</title>
    
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
	<link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet">
	<script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://getbootstrap.com/docs/5.0/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/_js/induxsoft.controls.js"></script>
	<script src="/_js/induxsoft.controls.editable.js"></script>
	<script src="/_js/model.js"></script>
		
</head>

<body>
	<style>
		:root
		{
            --filter-panel-height: 15.648rem;
            --table-cases-height: 30rem;
        }
		:root
		{
			--principal-color: #0266C8;
			--text-principal-color: #0266C8;
			--ligth-gray: #f5f5f5;
			--medium-gray: #888;
			--error-color:red;
		}
		.placeholder-glow .placeholder
		{animation: placeholder-glow 2s ease-in-out infinite;}
		.placeholder {
			/*display: inline-block;*/
			min-height: 1em;
			vertical-align: middle;
			cursor: wait;
			background-color: currentcolor;
			opacity: .5;
		}
		@keyframes placeholder-glow {
		  50% {
			opacity: .2;
		  }
		}
        .colorb
        {
            background:white !important;
            border:1px solid blue !important;
            border-radius: 50%;
            border-top: none !important;
            width: 20px !important;
            height: 20px !important;
        }
		.induxsoftLoginFormSpinner 
		{
				display: inline-block;
				width: 15px;
				height: 15px;
				background-color: var(--text-principal-color);
				border: 1px solid var(--principal-color);
				animation-name: induxsoftLoginFormSpin;
				animation-duration: 500ms;
				animation-iteration-count: infinite;
				animation-timing-function: linear; 
		}
		.nav-tabs .nav-link.active
		{
            border:#F0F8FF !important;
            border-bottom:2px solid #0B5ED7 !important;
            text-decoration: none !important;
            color: #000 !important;
            background-color: #F0F8FF !important;
        }
		  @keyframes induxsoftLoginFormSpin 
		  {
				from {
					transform:rotate(0deg);
				}
				to {
					transform:rotate(360deg);
				}
			}
	</style>
	
    #<@@(@http_context,"response/text")>
		
	
</body>

</html>
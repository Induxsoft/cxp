    financiar::&db,&data
    {
        do dbr.begin(db)
        
        idcxp = uuid()

        new dcxp
        {
            @"sys_pk": 0
            @"sys_guid": idcxp
            @"sys_dtcreated*": now()
            @"sys_timestamp*": now()
            @"aplicable": @false
            @"aplicacion*": str2dt(@@(data,"$fecha_aplicacion"))
            @"auditado": @false
            @"basecm": 0
            @"bonificaciones": 0.0
            @"contabilizado": @false
            @"debe": @@(data,"#importe")
            @"documento": @@(data,"#documento")
            @"fecha*": str2dt(@@(data,"$fecha_documento"))
            @"fultmoratorios*": str2dt(@@(data,"$fecha_documento"))
            @"haber": 0.0
            @"intfinancieros": 0.0
            @"intmoratorios": 0.0
            @"notas": @@(data,"$notas")
            @"pagos": 0.0
            @"porimpuestocap": 0.0
            @"porimpuestofin": 0.0
            @"porimpuestomor": 0.0
            @"referencia": @@(data,"$referencia")
            @"relacionadoa": 0
